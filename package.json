{
  "name": "cocoa-inventory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@testing-library/dom": "^9.3.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/user-event": "^13.5.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.6.0",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.15.0",
    "react-scripts": "^0.0.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "db:start": "powershell -ExecutionPolicy Bypass -File scripts/start-local-db.ps1",
    "db:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-local-db.ps1",
    "lint": "eslint src Backend",
    "lint:frontend": "eslint src",
    "lint:backend": "eslint Backend",
    "lint:fix": "eslint src --fix",
    "check:backend": "powershell -ExecutionPolicy Bypass -File scripts/check-backend.ps1",
    "smoke:startup": "node scripts/smoke-startup.mjs",
    "start": "set PORT=3000&& set BROWSER=chrome&&react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:backend": "node --test Backend/*.test.js",
    "eject": "react-scripts eject",
    "start-backend": "npm run db:start && node Backend/server.js",
    "build-and-deploy": "npm run build && npm run start-backend",
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1"
  },
  "rules": {
    "react/jsx-no-target-blank": "off"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "concurrently": "^9.2.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0"
  }
}
